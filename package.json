{
  "name": "sellerdesk",
  "version": "1.0.0",
  "description": "SellerDesk - Meesho Seller Management PWA",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "npx vite build && npm run build:server",
    "start": "node dist-server/index.js",
    "build:server": "esbuild server/index.ts --bundle --platform=node --outfile=dist-server/index.js --external:@libsql/client",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "@types/connect-sqlite3": "^0.9.6",
    "connect-sqlite3": "^0.9.16",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.36.4",
    "esbuild": "^0.24.0",
    "express": "^4.21.1",
    "express-session": "^1.18.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "vite": "^5.4.10"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^22.8.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.28.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite-plugin-pwa": "^0.21.0"
  }
}
